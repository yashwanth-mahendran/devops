# {{ ansible_managed }}
# Virtual host configuration for {{ item.name }}

{% if item.ssl | default(false) %}
# HTTP redirect to HTTPS
server {
    listen {{ nginx_http_port }};
    listen [::]:{{ nginx_http_port }};
    server_name {{ item.server_name | default(item.name) }};

    return 301 https://$server_name$request_uri;
}
{% endif %}

server {
{% if item.ssl | default(false) %}
    listen {{ nginx_https_port }} ssl http2;
    listen [::]:{{ nginx_https_port }} ssl http2;
    
    ssl_certificate {{ nginx_ssl_dir }}/{{ item.name }}.crt;
    ssl_certificate_key {{ nginx_ssl_dir }}/{{ item.name }}.key;
{% else %}
    listen {{ nginx_http_port }};
    listen [::]:{{ nginx_http_port }};
{% endif %}

    server_name {{ item.server_name | default(item.name) }};
    root {{ item.root | default(nginx_default_root + '/' + item.name) }};
    index {{ item.index | default('index.html index.htm') }};

    # Access log
    access_log {{ nginx_log_dir }}/{{ item.name }}_access.log {{ nginx_log_format }};
    error_log {{ nginx_log_dir }}/{{ item.name }}_error.log;

{% if item.locations is defined %}
{% for location in item.locations %}
    location {{ location.path }} {
{% if location.proxy_pass is defined %}
        proxy_pass {{ location.proxy_pass }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout {{ nginx_proxy_read_timeout }};
        proxy_connect_timeout {{ nginx_proxy_connect_timeout }};
{% elif location.try_files is defined %}
        try_files {{ location.try_files }};
{% endif %}
{% if location.extra_config is defined %}
{{ location.extra_config | indent(8) }}
{% endif %}
    }

{% endfor %}
{% else %}
    location / {
        try_files $uri $uri/ =404;
    }
{% endif %}

    # Deny access to hidden files
    location ~ /\. {
        deny all;
    }

{% if item.extra_server_config is defined %}
{{ item.extra_server_config | indent(4) }}
{% endif %}
}
