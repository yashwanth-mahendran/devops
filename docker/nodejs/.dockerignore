# .dockerignore template for Node.js
# ====================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
coverage/
.nyc_output/

# Development files
*.md
!README.md
LICENSE
.editorconfig

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*
.dockerignore

# Environment files
.env
.env.*
*.local

# Test files
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
jest.config.*
.jest/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Secrets (never commit these!)
*.pem
*.key
*.crt
secrets/
credentials/
