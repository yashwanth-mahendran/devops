# .dockerignore template for Java applications
# =============================================

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*
.dockerignore

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Test reports
test-results/
surefire-reports/
failsafe-reports/

# Documentation
docs/
*.md
!README.md

# Kubernetes
k8s/
helm/

# Environment
.env
.env.*

# Secrets
*.pem
*.key
*.jks
secrets/
