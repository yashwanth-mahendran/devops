# .dockerignore template for Python/FastAPI
# ==========================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
ENV/
env/
.env/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*
.dockerignore

# Environment files
.env
.env.*

# Documentation
docs/
*.md
!README.md

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Mypy
.mypy_cache/

# Secrets
*.pem
*.key
secrets/
